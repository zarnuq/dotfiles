#!/bin/sh
# runit USER service manager: ~/.local/sv, supervised by the per-user
# `runsvdir ~/.local/sv` from reach's autostart. No sudo/doas — everything runs
# as you. fzf to pick + act; the list re-renders so you can toggle several in a
# row. Bound to a floating kitty (Super+Z). For SYSTEM services (/etc/sv) use
# `ssvfzf` (split out so its one-time doas elevation doesn't tangle with this).
#
# The service dir *is* the supervised set (no /service symlink layer), so
# enable/disable = remove/create a `down` file inside the service dir.
#
# Glyphs:  ● running   ○ enabled but stopped   · disabled
# Keys:
#   enter   toggle running (sv up / sv down)
#   ctrl-e  enable  (rm down file) + start
#   ctrl-d  disable (touch down file) + stop
#   ctrl-r  restart
#   tab     multi-select (action applies to every selection)
#   esc     quit

USERSV="$HOME/.local/sv"
export SVDIR="$USERSV"

build_list() {
    [ -d "$USERSV" ] || return

    unames=$(
        for path in "$USERSV"/*; do
            [ -f "$path/run" ] || continue
            printf '%s ' "${path##*/}"
        done
    )
    [ -n "$unames" ] || return

    running=$(sv status $unames 2>/dev/null \
        | awk '/^run:/ { sub(/:$/, "", $2); print $2 }' | tr '\n' ' ')

    for path in "$USERSV"/*; do
        [ -f "$path/run" ] || continue
        name=${path##*/}
        if [ -f "$path/down" ]; then
            glyph='\033[90m·\033[0m'
        else
            case " $running " in
                *" $name "*) glyph='\033[32m●\033[0m' ;;
                *)           glyph='\033[33m○\033[0m' ;;
            esac
        fi
        printf "$glyph\t%s\n" "$name"
    done
}

while true; do
    sel=$(build_list \
            | sort -k2 \
            | fzf --ansi --no-sort --reverse --multi \
                  --delimiter='\t' --with-nth=1,2 \
                  --prompt 'usr service> ' \
                  --header $'enter: start/stop   ctrl-e: enable   ctrl-d: disable   ctrl-r: restart   tab: multi' \
                  --expect=ctrl-e,ctrl-d,ctrl-r) || exit 0

    key=$(printf '%s\n' "$sel" | head -n1)
    picks=$(printf '%s\n' "$sel" | tail -n +2 | awk -F'\t' 'NF>1 {print $2}')
    [ -n "$picks" ] || exit 0

    printf '%s\n' "$picks" | while IFS= read -r name; do
        [ -n "$name" ] || continue
        dir="$USERSV/$name"
        case "$key" in
            ctrl-e)
                rm -f "$dir/down"
                sv up "$name" 2>/dev/null
                ;;
            ctrl-d)
                sv down "$name" 2>/dev/null
                touch "$dir/down"
                ;;
            ctrl-r)
                sv restart "$name" 2>/dev/null
                ;;
            *)
                if sv status "$name" 2>/dev/null | grep -q '^run:'; then
                    sv down "$name" 2>/dev/null
                else
                    rm -f "$dir/down"
                    sv up "$name" 2>/dev/null
                fi
                ;;
        esac
    done
done
