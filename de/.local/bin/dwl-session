#!/bin/sh
# dwl session launcher with per-session logging, for diagnosing crashes.
# Each login writes a new timestamped log; keeps the newest $keep, prunes older.
# 'latest.log' always points at the current session. Captures stdout+stderr
# (wlroots prints crash info to stderr).
# Lockout-safe: if log setup fails, start dwl unlogged rather than block login.

logdir="${XDG_STATE_HOME:-$HOME/.local/state}/dwl"
keep=20

if mkdir -p "$logdir" 2>/dev/null; then
    logfile="$logdir/dwl-$(date +%Y%m%d-%H%M%S).log"
    # prune: keep only the $keep most recent session logs
    ls -1t "$logdir"/dwl-*.log 2>/dev/null | tail -n +$((keep + 1)) | xargs -r rm -f
    ln -sf "$logfile" "$logdir/latest.log"
    exec dbus-run-session dwl >"$logfile" 2>&1
fi
exec dbus-run-session dwl
