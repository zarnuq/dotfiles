#!/bin/sh
# Gamma/brightness D-Bus service (rs.wl-gammarelay). Needs the compositor's
# wayland socket + the session bus. runit respawns it after a WM restart (it
# exits when the old display goes away) and across the boot monitor-bringup
# race, so it's always back up — redshift.sh / brightness.sh just drive it.
# wl-gammarelay-rs is a nix-only binary; exec it by absolute path so a stale
# runsvdir with an unexpanded $HOME in PATH can't break the lookup.
gammarelay="$HOME/.nix-profile/bin/wl-gammarelay-rs"
bus="${DBUS_SESSION_BUS_ADDRESS#unix:path=}"
# WAYLAND_DISPLAY may be stale if runsvdir outlives a compositor restart.
# Scan for the live socket instead of trusting the inherited env.
while [ ! -S "$bus" ]; do sleep 0.2; done
wl=$(ls "${XDG_RUNTIME_DIR}"/wayland-[0-9] 2>/dev/null | head -1)
while [ -z "$wl" ]; do sleep 0.2; wl=$(ls "${XDG_RUNTIME_DIR}"/wayland-[0-9] 2>/dev/null | head -1); done
export WAYLAND_DISPLAY="${wl##*/}"
exec "$gammarelay"
