#!/bin/sh
# eww desktop widgets, self-contained runit service.
#
# The SUPERVISED process must be long-lived, so we exec the eww *daemon* in the
# foreground (--no-daemonize). Opening the widgets is a one-shot client action;
# running THAT as the service makes runsv flap it every second, and each
# restart close-alls + reopens the widgets (the flicker you were seeing). So we
# open the dashboard once, in the background, after the daemon's socket is up.
EWW_DIR="$HOME/.config/eww"
DASH="eww --config $EWW_DIR"

# Needs the session bus + a live wayland socket. Both may be absent/stale if
# runsvdir outlives a compositor restart, so wait for them like the other
# wayland user services do instead of trusting the inherited env.
bus="${DBUS_SESSION_BUS_ADDRESS#unix:path=}"; bus="${bus%%,*}"
while [ ! -S "$bus" ]; do sleep 0.2; done
wl=$(ls "${XDG_RUNTIME_DIR}"/wayland-[0-9] 2>/dev/null | head -1)
while [ -z "$wl" ]; do sleep 0.2; wl=$(ls "${XDG_RUNTIME_DIR}"/wayland-[0-9] 2>/dev/null | head -1); done
export WAYLAND_DISPLAY="${wl##*/}"

# Detect which monitor to use (0 for laptop, 1 for desktop) and pick a scale.
# scale drives BOTH the CSS sizes (eww.scss via _scale.scss) and the window
# geometry (eww.yuck via the SCALE var). 1.0 = baseline (ultrawide, unchanged).
if wlr-randr | grep -q "DP-2"; then
    monitor="1"    # Desktop ultrawide (3440x1440)
    scale="1.0"
else
    monitor="0"    # Laptop (1920x1200) — shrink the dashboard to fit
    scale="0.85"   # <-- tune this: <1.0 smaller, >1.0 bigger
fi

open_dash() {
    widgets="clock cpu net-graph tray weather notifications mpd outlook ports vpn brightness"
    # Wait for the daemon (we start it below) before talking to its socket.
    until $DASH ping >/dev/null 2>&1; do sleep 0.2; done
    # CSS side: eww.scss does `@import "scale"` and multiplies px by $scale.
    printf '$scale: %s;\n' "$scale" > "$EWW_DIR/_scale.scss"
    # Recompile the SCSS with the new $scale before opening windows.
    $DASH reload >/dev/null 2>&1 || true
    # Geometry side: scale is a per-window arg (defwindow can't see globals).
    for widget in $widgets; do
        $DASH open --screen "$monitor" --arg "scale=$scale" "$widget"
    done
}

# Open the dashboard once, then hand off to the daemon in the foreground so
# runsv supervises the right process.
open_dash &
exec $DASH daemon --no-daemonize
